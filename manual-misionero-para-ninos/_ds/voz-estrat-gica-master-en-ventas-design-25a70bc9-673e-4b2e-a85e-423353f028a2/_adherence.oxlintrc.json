{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/forms/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat))/i]",
        "message": "Font not provided by the design system. Available: Montserrat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|dark|neutral|danger)$/]",
        "message": "<Badge> tone must be one of 'accent' | 'dark' | 'neutral' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconPosition|fullWidth|disabled|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconPosition, fullWidth, disabled, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|dark|outline|ghost|on-dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'dark' | 'outline' | 'ghost' | 'on-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Button> iconPosition must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|theme|elevation|padding|accentBorder|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, theme, elevation, padding, accentBorder, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|muted|dark|accent)$/]",
        "message": "<Card> theme must be one of 'light' | 'muted' | 'dark' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:none|sm|md|lg|glow)$/]",
        "message": "<Card> elevation must be one of 'none' | 'sm' | 'md' | 'lg' | 'glow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg|xl)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|theme|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange, theme, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Checkbox> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComparePoint'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|type|theme|style|key|ref|className|style|children)$/]",
        "message": "<ComparePoint> doesn't accept that prop. Declared props: children, type, theme, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComparePoint'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:do|dont)$/]",
        "message": "<ComparePoint> type must be one of 'do' | 'dont'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComparePoint'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark|accent)$/]",
        "message": "<ComparePoint> theme must be one of 'light' | 'dark' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|theme|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, theme, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Input> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|description|variant|theme|style|key|ref|className|style|children)$/]",
        "message": "<ProcessStep> doesn't accept that prop. Declared props: number, title, description, variant, theme, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessStep'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|circle)$/]",
        "message": "<ProcessStep> variant must be one of 'plain' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessStep'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<ProcessStep> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBig'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|caption|source|theme|align|style|key|ref|className|style|children)$/]",
        "message": "<StatBig> doesn't accept that prop. Declared props: value, caption, source, theme, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBig'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<StatBig> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBig'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatBig> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, variant, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:green|black|outline-green|outline-dark|soft)$/]",
        "message": "<Tag> variant must be one of 'green' | 'black' | 'outline-green' | 'outline-dark' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:bars|height|color|animated|align|glow|style|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: bars, height, color, animated, align, glow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|bottom)$/]",
        "message": "<Waveform> align must be one of 'center' | 'bottom'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
